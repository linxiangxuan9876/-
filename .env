# 4S店售后知识库 - 环境变量配置
# 请填入实际值，不要提交到 Git！

# JWT 密钥（32位强密钥）
SECRET_KEY=

# OpenAI API Key
OPENAI_API_KEY=

# 数据库（默认使用 SQLite 本地数据库）
DATABASE_URL=sqlite:///./knowledge_base.db

# CORS 配置（生产环境指定具体域名）
CORS_ORIGINS=https://men-dian-zhi-shi-ku.onrender.com

# 文件上传配置
MAX_FILE_SIZE=52428800
ALLOWED_FILE_EXTENSIONS=.pdf,.docx,.doc,.xlsx,.xls,.txt,.csv

# OpenAI 模型配置
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
